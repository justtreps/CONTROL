{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["sin1"],
  "crons": [
    { "path": "/api/cron/sync-services", "schedule": "0 3 * * *" },
    { "path": "/api/cron/test-bot", "schedule": "0 * * * *" },
    { "path": "/api/cron/scraper", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/scoring", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/pool-orchestrator", "schedule": "* * * * *" },
    { "path": "/api/cron/pool-health-check", "schedule": "0 3 * * *" },
    { "path": "/api/cron/pool-cleanup", "schedule": "0 4 * * 0" },
    { "path": "/api/cron/suggestions-refill", "schedule": "*/15 * * * *" }
  ]
}
