# Database (Supabase pooled connection — use the "Connection pooling" URL from Supabase dashboard)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct URL (optional, for migrations). Set to the non-pooled URL.
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Upstash Redis (used later for rate limiting + QStash triggers)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# BulkMedya — can also be stored encrypted in Config table via /config UI
BULKMEDYA_API_KEY=
BULKMEDYA_API_URL=https://bulkmedya.org/api/v2

# RapidAPI — single key for all RapidAPI endpoints (Instagram scraper + TikTok scraper)
RAPIDAPI_KEY=

# Anthropic API — used by /api/pool/seeds/suggestions-dynamic to have Claude
# Haiku propose fresh seed candidates on the /pool seeds refresh. Optional:
# the endpoint falls back to the hardcoded pool in lib/pool/suggested-seeds.ts
# when the key is missing or the API call fails.
ANTHROPIC_API_KEY=

# Dashboard auth — simple password, also used as HMAC secret for session cookies
ADMIN_PASSWORD=change-me-to-a-long-random-string

# Secret for /api/cron/* endpoints — Vercel Cron sends Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=change-me-to-a-long-random-string

# Bearer token for POST /api/order — MyBoost backend uses this to place orders
ORDER_API_KEY=change-me-to-a-long-random-string

# Safety: when true (default), /api/order simulates placement — no real BulkMedya call.
# Set to false only when you've validated routing logic.
DRY_RUN=true

# App URL (used in emails / absolute links later)
NEXT_PUBLIC_APP_URL=http://localhost:3000
