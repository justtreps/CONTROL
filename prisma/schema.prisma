// myscore — Quality scoring router for BulkMedya services
// See /Users/cashout/Downloads/myscore-spec.md for context

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Service {
  id              Int      @id @default(autoincrement())
  bulkmedyaId     Int      @unique
  name            String
  category        String
  platform        String
  serviceType     String
  ratePerK        Float
  minQuantity     Int
  maxQuantity     Int
  refillSupported Boolean
  cancelSupported Boolean  @default(false)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Routing: which pool the testbot draws from when this service's
  // cooldown expires.
  //   'follower_test'   — abonné / subscriber / follower services
  //   'engagement_test' — like / view / share / save services
  //   'unknown'         — the classifier couldn't decide; testbot
  //                       skips until an operator triages via the
  //                       services-review page
  poolType        String   @default("unknown")

  // Optional ISO 2-letter country code when the service is geo-
  // targeted (e.g. "Instagram Followers [ 🇫🇷 France ]" → "FR").
  // null means the service accepts any country.
  targetCountry   String?

  // Flipped true by the classifier when its confidence is too low to
  // assign a poolType — surfaces in /config/services-review for
  // manual triage.
  classificationManualReview Boolean @default(false)

  // Denormalised MAX(TestOrder.placedAt). Null = never tested.
  // Stamped on every TestOrder.create and backfilled via
  // /api/pool/backfill-last-tested after the column ships. Drives
  // the obsolescence filter in /config/services-review ("jamais
  // testé / > 6 mois / > 1 an / > 2 ans") — a row tested recently
  // and routinely is low-priority for triage even if it's in the
  // manual-review queue, while rows never tested or stale are
  // candidates for disable/archival.
  lastTestedAt    DateTime?

  testOrders      TestOrder[]
  scores          ServiceScore[]
  productCandidacies ProductServiceCandidate[]

  @@index([platform, serviceType, active])
  @@index([poolType, active])
  @@index([targetCountry])
  @@index([lastTestedAt])
}

// MyBoost product catalog — the 8 SKUs the user actually sells. The
// matcher (src/lib/catalogue/matcher.ts) evaluates every active
// BulkMedya Service against each product's rules and fills Product
// ServiceCandidate rows. Routing, scoring and the testbot all key off
// those candidacies instead of the raw Service.poolType heuristic.
model MyBoostProduct {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  displayName      String
  platform         String   // "instagram" | "tiktok"
  productType      String   // "followers" | "likes" | "views" | "shares" | "saves"
  // Free-form JSON so the matcher can evolve per-product without
  // schema churn (e.g. extra blacklist words, min-rate thresholds).
  matchingCriteria Json     @default("{}")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  candidates       ProductServiceCandidate[]

  @@index([platform, productType])
  @@index([isActive])
}

// Many-to-many link between a MyBoostProduct and the BulkMedya
// Services that match its whitelist. currentScore + rank are filled
// by the scoring engine on each pass.
model ProductServiceCandidate {
  id              Int      @id @default(autoincrement())
  productId       Int
  product         MyBoostProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  serviceId       Int
  service         Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Matcher output — "is this a valid candidate right now?". Flipped
  // false if the service drops out of scope on a re-match (inactive,
  // renamed, reclassified). We keep the row around instead of
  // deleting so scoring history survives.
  isEligible      Boolean  @default(true)

  // Operator override — "never use this service for this product no
  // matter what the matcher says". Set from the catalogue detail UI.
  forceExcluded   Boolean  @default(false)

  // Scoring outputs. currentScore is 0-100; rank is position within
  // the product's ranked candidate list (rank=1 is the top pick the
  // router will try first). Both null until the scoring engine has
  // seen enough test orders.
  currentScore    Float?
  rank            Int?

  // Geo detected by the matcher after stripping emoji / country
  // suffixes from the service name. null = global service.
  targetCountry   String?

  lastScoredAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([productId, serviceId])
  @@index([productId, rank])
  @@index([productId, isEligible, forceExcluded])
  @@index([serviceId])
}

model TestAccount {
  id           Int       @id @default(autoincrement())
  platform     String
  username     String
  userId       String
  active       Boolean   @default(true)
  lastTestedAt DateTime?
  createdAt    DateTime  @default(now())

  // Pool routing — "follower_test" means the account has 0 posts and
  // is used to test follower/subscriber services. "engagement_test"
  // means the account has at least one live post (tracked in Test
  // AccountMedia) and is used to test likes / views / shares. All
  // pre-migration rows keep the default so nothing breaks.
  accountType            String    @default("follower_test")

  // Detected nationality (ISO 2-letter code) + how confident the
  // detector was. null/'unknown' means the detector couldn't pin one
  // down — still usable, just not for geo-targeted services.
  detectedCountry        String?
  countryConfidence      String    @default("unknown") // 'high' | 'medium' | 'low' | 'unknown'

  // ── Pool system extensions (see pool-full-control.md) ──
  // Lifecycle state for accounts in the pool:
  //   available → assigned → consumed  (normal happy path, 1 account = 1 test)
  //   available → invalid              (disqualified by health check)
  //   consumed|invalid → archived      (after 90d, via cleanup job)
  status                 String    @default("available")

  assignedTestOrderId    Int?
  assignedAt             DateTime?
  consumedAt             DateTime?

  firstSeenAt            DateTime  @default(now())
  lastCheckedAt          DateTime  @default(now())
  lastFollowerCount      Int?
  lastMediaCount         Int?
  lastFollowingCount     Int?

  // ── Engagement-extraction metadata ───────────────────────────────
  // Set to true once we've had a trusted oracle read on this account —
  // the follower scraper already calls the oracle per candidate so
  // lastMediaCount is fresh and can drive the phase-1 extraction flow
  // without a second RapidAPI roundtrip. Legacy rows default to false
  // until the next health-check refresh sets it.
  hasPostsInfo           Boolean   @default(false)
  // When did we last run /user/posts against this account for the
  // engagement pool? Null = never. Extract flow re-picks after 30d.
  engagementCheckedAt    DateTime?
  engagementPostsFound   Int?
  // True when the last extract pass returned zero qualifying posts —
  // skip on future passes until the parent is re-checked (the 30d
  // revisit window clears this flag).
  engagementExhausted    Boolean   @default(false)

  // 'big_account_followers' | 'random_username' | 'manual'
  scrapeSource           String?
  scrapeSeedAccount      String?

  // 'banned' | 'became_active' | 'became_private' | 'deleted' | 'other'
  invalidReason          String?
  invalidatedAt          DateTime?

  notes                  String?

  testOrders             TestOrder[]
  posts                  TestPost[]

  @@unique([platform, username])
  @@index([platform, active])
  @@index([platform, status])
  @@index([status, assignedAt])
  @@index([platform, status, firstSeenAt])
  @@index([platform, userId])
  // Supports the daily health-check's orderBy: {lastCheckedAt: "asc"}
  // filtered by status='available'. Without it the 6-hourly cron
  // sorts in-memory, which doesn't scale past a few thousand rows.
  @@index([status, lastCheckedAt])
  // Supports testbot's pickAndAssignAccount routing by accountType
  // and detectedCountry.
  @@index([platform, status, accountType, detectedCountry])
}

// A single post / reel / video that lives in the engagement pool.
//
// The engagement pool is a pool of POSTS — not accounts. When a likes /
// views / shares / saves service is tested we pick one TestPost at a
// time (not its parent account), hand its URL to BulkMedya, and flip
// it available → assigned → consumed. A single parent TestAccount can
// contribute N posts if they all pass the freshness + natural-likes
// filters, so one scraped account can fuel several tests instead of
// exactly one.
//
// The parent TestAccount FK is kept for traceability (detectedCountry
// routing, health-check cascades) but does NOT carry the engagement
// lifecycle anymore — that lives on this row.
model TestPost {
  id                Int       @id @default(autoincrement())
  testAccount       TestAccount @relation(fields: [testAccountId], references: [id], onDelete: Cascade)
  testAccountId     Int
  platform          String    // denormalized from parent for fast filtering
  mediaId           String    // platform-native id (IG pk, TT aweme_id)
  mediaUrl          String    // permalink we hand to BulkMedya
  mediaType         String    // 'post' | 'reel' | 'video'
  postedAt          DateTime?
  naturalLikesCount Int       @default(0)

  // Lifecycle — mirrors TestAccount:
  //   available → assigned → consumed   (normal happy path)
  //   available → invalid                 (deleted / parent banned / etc.)
  status                 String    @default("available")
  active                 Boolean   @default(true)
  assignedTestOrderId    Int?
  assignedAt             DateTime?
  consumedAt             DateTime?
  // 'deleted'         — provider returned 404 on health check
  // 'parent_invalid'  — owner TestAccount became invalid
  // 'manual'          — operator flipped it
  invalidReason          String?
  invalidatedAt          DateTime?

  firstSeenAt            DateTime  @default(now())
  lastCheckedAt          DateTime  @default(now())

  // Where did this post come from?
  //   'from_follower_pool' — phase-1 extract: we already had the
  //                          parent account in the follower pool,
  //                          1 RapidAPI call to fetch its posts.
  //   'seeds'              — phase-2 seed scrape: 2 calls (oracle
  //                          on the candidate + posts).
  scrapeSource           String    @default("seeds")

  @@unique([testAccountId, mediaId])
  @@index([platform, status])
  @@index([status, assignedAt])
  @@index([platform, status, firstSeenAt])
  @@index([status, lastCheckedAt])
  @@index([scrapeSource, status])
}

// Single-row config for the pool system (id=1). Editable from the /pool UI.
model PoolConfig {
  id                               Int      @id @default(1)

  // Auto-refill
  autoRefillEnabled                Boolean  @default(true)
  refillThresholdInstagram         Int      @default(500)
  refillTargetInstagram            Int      @default(1000)
  refillThresholdTiktok            Int      @default(500)
  refillTargetTiktok               Int      @default(1000)

  // RapidAPI budget caps per run. Dropped from 10000/3000 to 3000/
  // 1500 after seeing the daily quota hit ~7500 calls/24h — a tighter
  // ceiling per run amortizes better across the day and leaves
  // headroom for measurement bot + testbot + seeds-health-check.
  maxRapidapiCallsPerScrapeRun     Int      @default(10000)
  maxRapidapiCallsPerHealthcheck   Int      @default(1500)
  maxAttemptsMethodB               Int      @default(5000)
  maxPagesPerSeed                  Int      @default(50)

  // Split between big-account scraping (A) and random-username probing (B)
  methodARatio                     Float    @default(0.7)

  // Global kill switch for Phase B (random-username probing). When
  // false the scraper skips Phase B entirely even if methodARatio < 1,
  // and the /pool UI grays out the Method-B configuration surface.
  methodBEnabled                   Boolean  @default(true)

  // Health check schedule (cron expression — read by the orchestrator)
  healthCheckEnabled               Boolean  @default(true)
  healthCheckCron                  String   @default("0 3 * * *")

  // Fresh-account qualification thresholds. Used BOTH at scrape time
  // (accept candidate when value <= threshold) AND at health-check
  // time (invalidate row when value > threshold). Unified into one
  // config so the two passes can never drift — historically there
  // were separate `maxFollowerCount` (scrape) and `invalidateIf
  // FollowerAbove` (health) fields which got out of sync, letting
  // accounts land in the pool that the next cron would immediately
  // invalidate. That separate field is dropped in this revision.
  //
  // maxMediaCount is effectively disabled (999999) because a profile
  // with a handful of posts is still usable — what matters is that
  // the account isn't tracking anyone yet and has near-zero
  // followers.
  // Platform-split follower thresholds. Instagram uses
  // maxFollowerCount (strict, 5) because IG accounts rarely grow
  // organically without intent. TikTok uses maxFollowerCountTiktok
  // (tolerant, 30) because TT's viral dynamics push even dormant
  // accounts to 5-30 followers through random exposure — a 5-cap
  // there would invalidate perfectly good test accounts.
  maxFollowerCount                 Int      @default(5)
  maxFollowerCountTiktok           Int      @default(30)
  maxMediaCount                    Int      @default(999999)
  maxFollowingCount                Int      @default(100)
  requireNotPrivate                Boolean  @default(true)

  // Stricter health-check guardrail reserved for media_count. Kept
  // separate from maxMediaCount for now since media_count checks
  // might evolve independently (we routinely accept posts at scrape
  // time but could want to flag later growth).
  invalidateIfMediaAbove           Int      @default(999999)

  // ── Engagement pool ──────────────────────────────────────────────
  // When enabled, accounts scraped with mediaCount >= engagementPostsMin
  // are classified as 'engagement_test' candidates and their recent
  // posts are sampled. Those posts feed tests for like / view / share
  // services. Disabled by default so the original follower_test-only
  // pool behaviour is preserved until the operator opts in. Country
  // routing is handled at MyBoost→CONTROL time, not here; TestAccount.
  // detectedCountry is kept for that downstream use.
  engagementPoolEnabled            Boolean  @default(false)
  engagementPoolTargetInstagram    Int      @default(500)
  engagementPoolTargetTiktok       Int      @default(500)
  engagementPostsMin               Int      @default(1)
  engagementLikesMaxPerPost        Int      @default(20)
  engagementFreshnessMaxDays       Int      @default(30)

  // BulkMedya catalog sync cadence. The Vercel cron fires every hour
  // (0 * * * *) but the endpoint gates on this field + lastServices
  // SyncAt — sync actually runs only when the elapsed time since the
  // last successful run ≥ servicesSyncFrequencyHours. Default 1 =
  // every hour (no gating).
  servicesSyncFrequencyHours       Int       @default(1)
  lastServicesSyncAt               DateTime?
  lastServicesSyncResult           Json?
  // In-flight lock for the fire-and-forget manual sync + scheduled
  // cron. Set at dispatch, cleared at completion (or on error). Any
  // second trigger while this is recent (<10 min) gets "already_
  // running". Values older than 10 min are treated as stale locks
  // left by a dead worker and ignored.
  servicesSyncStartedAt            DateTime?

  updatedAt                        DateTime @updatedAt
}

// Big accounts whose followers list we paginate (scrape method A).
model PoolSeedAccount {
  id             Int       @id @default(autoincrement())
  platform       String
  username       String

  // Stable platform-side identifier resolved on the first health check.
  // Lets us survive username renames (which would otherwise break the
  // @@unique([platform, username]) lookup and make the seed unreachable).
  userId         String?

  enabled        Boolean   @default(true)
  priority       Int       @default(0)
  addedAt        DateTime  @default(now())

  // Last time the daily seeds health check verified this seed exists
  // and is still public. Null for never-checked (freshly added) seeds.
  lastCheckedAt  DateTime?

  // Cross-run error streak. The scraper increments this whenever it
  // hits a processing error on the seed (e.g. RapidAPI "Private
  // account"); it resets to 0 on a successful page. When the streak
  // crosses AUTO_DISABLE_PRIVATE_THRESHOLD AND the last reason looks
  // like a private/locked error, the scraper flips enabled=false
  // and logs action='auto_disabled_private' so operators can see
  // why. lastErrorReason records the most recent failure verbatim
  // so the log surfaces the actual provider message.
  consecutiveErrors  Int      @default(0)
  lastErrorReason    String?

  @@unique([platform, username])
  @@index([platform, enabled, priority])
}

// Audit log for the daily seeds health check. One row per decision
// (seed deleted + replaced, seed renamed, ok) so operators can scroll
// recent days' actions when they suspect a seed issue.
model PoolSeedHealthLog {
  id            Int      @id @default(autoincrement())
  platform      String
  // 'ok' | 'renamed' | 'deleted_mort'
  //   | 'replaced_from_cache' | 'cache_empty_refill_triggered'
  //   | 'error' | 'manual_trigger'
  action        String
  seedUsername  String   // username at the time of the check
  newUsername   String?  // rename target, or replacement handle
  reason        String?  // oracle message / transient error detail
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([platform, createdAt])
}

// Username prefixes for the random-probe scraper (method B).
model PoolUsernamePrefix {
  id      Int     @id @default(autoincrement())
  prefix  String  @unique
  enabled Boolean @default(true)
}

// Reserve of pre-generated seed suggestions, topped up by a Claude
// Haiku refill job (cron + on-demand). Reading from this table makes
// the /pool seeds "Suggestions" column instant — no user-visible
// Claude latency. Rows get drained as operators integrate or reject
// entries; the cron keeps the pool at >=100 per platform.
model PoolSeedSuggestionPool {
  id        Int      @id @default(autoincrement())
  platform  String   // 'instagram' | 'tiktok'
  username  String
  createdAt DateTime @default(now())

  @@unique([platform, username])
  @@index([platform, createdAt])
}

// Decision log for the suggested-seeds workflow: each row records
// that a given (platform, username) was either promoted to
// PoolSeedAccount (action='integrated') or dismissed (action='rejected')
// so the /api/pool/seeds/suggestions endpoint never surfaces it again.
model PoolSeedSuggestionAction {
  id        Int      @id @default(autoincrement())
  platform  String
  username  String
  action    String   // 'integrated' | 'rejected'
  actedAt   DateTime @default(now())

  @@unique([platform, username])
  @@index([platform, action])
}

// Run history for scrape / health-check / cleanup jobs, with a
// cooperative stop flag so the orchestrator can bail mid-batch.
model PoolJob {
  id             Int      @id @default(autoincrement())
  jobType        String   // 'scrape' | 'health_check' | 'cleanup'
  platform       String?  // null = multi-platform
  trigger        String   // 'manual' | 'cron' | 'auto_refill'
  // Which RapidApiKey this job is currently using. Set at creation
  // (round-robin via pickNextApiKey) and may drift during the run
  // if the original key caps and the IG client auto-switches to
  // another active key. null = no key assigned yet, or running
  // under the env-var fallback when no DB key exists.
  rapidApiKeyId  Int?

  status         String   @default("pending")
  // 'pending' | 'running' | 'completed' | 'stopped' | 'error'

  startedAt      DateTime @default(now())
  endedAt        DateTime?

  stats          Json?
  error          String?

  stopRequested  Boolean  @default(false)

  @@index([status, startedAt])
  @@index([jobType, status])
}

// RapidAPI keys manageable from /config. Each provider (instagram /
// tiktok) can have N active keys; the key manager picks them round-
// robin at job creation and auto-fails over to another active key
// inside a running job when the current one caps.
model RapidApiKey {
  id                 Int       @id @default(autoincrement())
  provider           String    // 'instagram' | 'tiktok'
  label              String
  token              String
  // 'active'   — available to be picked + receive traffic
  // 'capped'   — quota exceeded, skipped until resetDayOfMonth hits
  // 'disabled' — operator manually turned it off
  status             String    @default("active")
  quotaMonthly       Int?
  quotaUsed          Int       @default(0)
  resetDayOfMonth    Int?      // 1-31, clamped to month length at reset time
  rateLimitPerMin    Int?
  lastCappedAt       DateTime?
  lastUsedAt         DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([provider, status])
}

model TestOrder {
  id               Int      @id @default(autoincrement())
  service          Service  @relation(fields: [serviceId], references: [id])
  serviceId        Int
  testAccount      TestAccount @relation(fields: [testAccountId], references: [id])
  testAccountId    Int
  bulkmedyaOrderId String   @unique
  targetQuantity   Int
  baselineCount    Int
  placedAt         DateTime @default(now())
  completedAt      DateTime?

  // Lifecycle: 'running' (default) → 'completed' (delivered or T+7d)
  //                               → 'aborted_target_died' (mid-test)
  //                               → 'aborted_other' (rare: provider 404 etc)
  // Only 'completed' rows count towards the ServiceScore moving average.
  status           String   @default("running")
  abortReason      String?

  // Retry chain — when a target dies mid-test we abort the current
  // row and relaunch a new TestOrder on the same service with a
  // fresh target. retriedFrom points at the dead row so the UI can
  // collapse the chain into a single expandable history entry.
  // retryCount mirrors the chain depth (0 = fresh, 1 = first retry,
  // capped at 3 before giving up on the service this cycle).
  retriedFrom      Int?
  retriedFromOrder TestOrder?  @relation("TestOrderRetry", fields: [retriedFrom], references: [id], onDelete: NoAction, onUpdate: NoAction)
  retryOrders      TestOrder[] @relation("TestOrderRetry")
  retryCount       Int      @default(0)

  // Last time the poller/testbot re-fetched the target via RapidAPI.
  // Pre-test health check stamps this just before placing the order;
  // the adaptive poller stamps it on each poll.
  lastHealthCheckAt DateTime?

  // Adaptive polling state. { nextPollAt, currentIntervalMs,
  // consecutiveZeroDeltas }. Null → fallback fixed checkpoints
  // (legacy path via lib/scraper.ts) still drives measurements for
  // this row.
  pollingState     Json?

  measurements     Measurement[]
  polls            TestPoll[]

  @@index([serviceId, placedAt])
  @@index([status, placedAt])
  @@index([retriedFrom])
}

// Audit log of every adaptive-polling tick on a TestOrder. Scoring
// doesn't read this — it's purely for the UI timeline + cost audit.
// Measurement still owns the canonical checkpoint rows scoring reads.
model TestPoll {
  id              Int      @id @default(autoincrement())
  testOrder       TestOrder @relation(fields: [testOrderId], references: [id], onDelete: Cascade)
  testOrderId     Int
  polledAt        DateTime @default(now())
  deliveredQty    Int
  delta           Int      // this tick's delta vs previous poll
  targetStatus    String   // 'ok' | 'private' | 'deleted' | 'banned'
  intervalMsBefore Int     // the interval that preceded this poll (for audit)

  @@index([testOrderId, polledAt])
}

model Measurement {
  id           Int      @id @default(autoincrement())
  testOrder    TestOrder @relation(fields: [testOrderId], references: [id])
  testOrderId  Int
  checkedAt    DateTime @default(now())
  checkpoint   String
  actualCount  Int
  realismData  Json
  realismScore Float?

  @@unique([testOrderId, checkpoint])
  @@index([testOrderId, checkedAt])
}

model ServiceScore {
  id               Int      @id @default(autoincrement())
  service          Service  @relation(fields: [serviceId], references: [id])
  serviceId        Int
  currentScore     Float
  completionFactor Float
  realismScore     Float
  speedScore       Float
  dropScore        Float
  computedAt       DateTime @default(now())

  @@index([serviceId, computedAt])
}

model RoutingDecision {
  id                 Int      @id @default(autoincrement())
  platform           String
  serviceType        String
  quantity           Int
  targetUrl          String
  chosenServiceId    Int?
  chosenServiceScore Float?
  bulkmedyaOrderId   String?
  attempts           Int      @default(1)
  success            Boolean
  dryRun             Boolean  @default(false)
  errorMessage       String?
  decidedAt          DateTime @default(now())

  @@index([decidedAt])
  @@index([chosenServiceId])
  @@index([success, dryRun])
}

model Config {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// Single-row (id=1) kill switch for each major subsystem. Every gated
// endpoint reads this once per request and 503s / skips if its toggle
// is false. Default: everything ENABLED so an empty row acts as a
// no-op, never a surprise outage.
model SystemToggle {
  id                       Int      @id @default(1)
  poolScrapeEnabled        Boolean  @default(true)
  poolHealthcheckEnabled   Boolean  @default(true)
  routingApiEnabled        Boolean  @default(true)
  testBotEnabled           Boolean  @default(true)
  scoringEngineEnabled     Boolean  @default(true)
  // When true, new TestOrders use the variable-interval adaptive
  // poller (see lib/testbot/poller.ts). When false, they fall back
  // to the legacy fixed checkpoints (T+5min / T+30min / T+1h /
  // T+6h / T+24h / T+7d) driven by lib/scraper.ts. Kill switch for
  // the operator in case the adaptive poller misbehaves in prod.
  adaptivePollingEnabled   Boolean  @default(true)
  // Runs the workflow executor cron. DEFAULT FALSE so a fresh
  // deploy never races the legacy individual crons — the operator
  // opts in once the 8 seeded workflows are verified (see
  // lib/workflows/executor.ts). Legacy crons stay running in
  // parallel; a follow-up migration commit will disable them once
  // the workflow engine proves stable.
  workflowExecutorEnabled  Boolean  @default(false)
  updatedAt                DateTime @updatedAt
}

// Visual workflow orchestrator. Each Workflow is a DAG of nodes
// stored as JSON (see lib/workflows/nodes.ts for the Node type).
// The master cron /api/cron/workflow-executor picks up cron-triggered
// workflows whose schedule matches + any paused WorkflowRun that's
// ready to resume, and advances them one node at a time.
model Workflow {
  id             Int      @id @default(autoincrement())
  slug           String   @unique
  displayName    String
  description    String?
  category       String   // 'health' | 'pool' | 'scoring' | 'sync' | 'catalogue' | 'custom'
  triggerType    String   // 'manual' | 'cron' | 'event'
  cronExpression String?  // 5-field cron when triggerType='cron'
  eventType      String?  // event name when triggerType='event'
  isActive       Boolean  @default(true)
  // Nodes as a JSON array. Shape:
  //   [{ id: "n1", type: "TRIGGER", config: {...}, nextNodeId: "n2" }, ...]
  // See lib/workflows/nodes.ts for exhaustive node types + config
  // schemas. JSON-as-config pattern lets new node types ship without
  // schema churn; validation happens at executor-dispatch time.
  nodes          Json     @default("[]")
  lastRunAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  runs           WorkflowRun[]

  @@index([isActive, triggerType])
  @@index([category])
}

model WorkflowRun {
  id             Int      @id @default(autoincrement())
  workflow       Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowId     Int
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  // 'running'   — in-flight on a node
  // 'completed' — reached the end of the graph cleanly
  // 'failed'    — a node threw; see logs for the stack
  // 'paused'    — stuck on a WAIT node; resumeAt will fire it again
  status         String   @default("running")
  currentNodeId  String?
  // Live variable bag passed between nodes (eg. FETCH_POOL stashes
  // its rows here so the next FILTER/LOOP can read them).
  context        Json     @default("{}")
  // Append-only log of { nodeId, at, level, message } entries.
  // Surface in the UI history drawer.
  logs           Json     @default("[]")
  // Pause/resume shuttle for WAIT nodes. resumeAt is the wall-clock
  // the master cron scans — "run is paused AND resumeAt <= now" is
  // the pick criterion. When the run resumes, executor re-enters at
  // currentNodeId, walks the remaining graph. pausedAt is just for
  // audit (age of the pause).
  pausedAt       DateTime?
  resumeAt       DateTime?
  resumedAt      DateTime?
  // Triggered by: 'cron' | 'manual' | 'event' | 'retry'
  trigger        String   @default("cron")
  // When run was fired from an event, carries the WorkflowEvent.id
  // so the UI can surface "why did this run start?".
  sourceEventId  Int?

  @@index([workflowId, startedAt])
  @@index([status])
  @@index([status, resumeAt])
}

// Event bus. Emitters call lib/workflows/events.ts:emit(type, payload).
// The master workflow-executor cron picks up unprocessed rows each
// tick and fires every workflow with matching triggerType='event' +
// eventType. Multiple workflows can listen to the same event type —
// each gets its own WorkflowRun with sourceEventId=this.id.
model WorkflowEvent {
  id            Int      @id @default(autoincrement())
  type          String   // e.g. "pool.below_threshold.follower"
  payload       Json     @default("{}")
  emittedAt     DateTime @default(now())
  processedAt   DateTime?
  // Count of workflow runs that fired from this event — audit.
  runsTriggered Int      @default(0)

  @@index([processedAt, emittedAt])
  @@index([type, emittedAt])
}

// Observability alert surface. A detector ticks every 2 min and
// emits zero-or-more DetectorResult rows; the engine reconciles
// them against this table — create new row per new code, update
// triggerCount + lastTriggeredAt on an already-active same-code
// row, and auto_resolve rows whose code no longer matches on the
// current tick.
//
// `code` is a semantic identifier the detector builds deterministically
// (e.g. "pool_below_min:instagram:follower"). NOT globally unique —
// after auto_resolve, the same code can re-fire later as a brand-new
// row. The pair (code, status='active') is what the reconciler
// looks up.
model Alert {
  id                Int      @id @default(autoincrement())
  code              String
  // 'infra' | 'pool' | 'job' | 'catalogue' | 'business' | 'rapidapi' | 'testbot'
  category          String
  // 'info' | 'warning' | 'critical'
  severity          String
  title             String
  description       String
  // Long-form "why did this fire". Detector packs concrete values
  // + thresholds + plausible causes so the operator can understand
  // from the drawer alone.
  explanation       String
  // What breaks downstream if this isn't handled.
  impact            String
  // Short human sentence "quoi faire" — rendered in the drawer.
  suggestedAction   String
  // 'link' | 'button' | null. Drives how the UI renders the action.
  //   link   → Next <Link href={actionPayload.href}>
  //   button → client-side fetch({method, endpoint, body})
  actionType        String?
  actionPayload     Json?
  // Anchor the alert to a concrete row when applicable — the UI
  // can surface a mini-card on the related page.
  relatedEntityType String?
  relatedEntityId   Int?

  // 'active' | 'acknowledged' | 'resolved' | 'auto_resolved'
  status            String   @default("active")

  firstTriggeredAt  DateTime @default(now())
  lastTriggeredAt   DateTime @default(now())
  resolvedAt        DateTime?
  // Every subsequent tick where the condition matches bumps this.
  // Surfaces as "déclenchée N fois" in the UI.
  triggerCount      Int      @default(1)

  acknowledgedBy    String?
  acknowledgedAt    DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, severity, category])
  @@index([code, status])
  @@index([lastTriggeredAt])
}
