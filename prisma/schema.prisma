// myscore — Quality scoring router for BulkMedya services
// See /Users/cashout/Downloads/myscore-spec.md for context

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Service {
  id              Int      @id @default(autoincrement())
  bulkmedyaId     Int      @unique
  name            String
  category        String
  platform        String
  serviceType     String
  ratePerK        Float
  minQuantity     Int
  maxQuantity     Int
  refillSupported Boolean
  cancelSupported Boolean  @default(false)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Routing: which pool the testbot draws from when this service's
  // cooldown expires.
  //   'follower_test'   — abonné / subscriber / follower services
  //   'engagement_test' — like / view / share / save services
  //   'unknown'         — the classifier couldn't decide; testbot
  //                       skips until an operator triages via the
  //                       services-review page
  poolType        String   @default("unknown")

  // Optional ISO 2-letter country code when the service is geo-
  // targeted (e.g. "Instagram Followers [ 🇫🇷 France ]" → "FR").
  // null means the service accepts any country.
  targetCountry   String?

  // Flipped true by the classifier when its confidence is too low to
  // assign a poolType — surfaces in /config/services-review for
  // manual triage.
  classificationManualReview Boolean @default(false)

  testOrders      TestOrder[]
  scores          ServiceScore[]

  @@index([platform, serviceType, active])
  @@index([poolType, active])
  @@index([targetCountry])
}

model TestAccount {
  id           Int       @id @default(autoincrement())
  platform     String
  username     String
  userId       String
  active       Boolean   @default(true)
  lastTestedAt DateTime?
  createdAt    DateTime  @default(now())

  // Pool routing — "follower_test" means the account has 0 posts and
  // is used to test follower/subscriber services. "engagement_test"
  // means the account has at least one live post (tracked in Test
  // AccountMedia) and is used to test likes / views / shares. All
  // pre-migration rows keep the default so nothing breaks.
  accountType            String    @default("follower_test")

  // Detected nationality (ISO 2-letter code) + how confident the
  // detector was. null/'unknown' means the detector couldn't pin one
  // down — still usable, just not for geo-targeted services.
  detectedCountry        String?
  countryConfidence      String    @default("unknown") // 'high' | 'medium' | 'low' | 'unknown'

  // ── Pool system extensions (see pool-full-control.md) ──
  // Lifecycle state for accounts in the pool:
  //   available → assigned → consumed  (normal happy path, 1 account = 1 test)
  //   available → invalid              (disqualified by health check)
  //   consumed|invalid → archived      (after 90d, via cleanup job)
  status                 String    @default("available")

  assignedTestOrderId    Int?
  assignedAt             DateTime?
  consumedAt             DateTime?

  firstSeenAt            DateTime  @default(now())
  lastCheckedAt          DateTime  @default(now())
  lastFollowerCount      Int?
  lastMediaCount         Int?
  lastFollowingCount     Int?

  // ── Engagement-extraction metadata ───────────────────────────────
  // Set to true once we've had a trusted oracle read on this account —
  // the follower scraper already calls the oracle per candidate so
  // lastMediaCount is fresh and can drive the phase-1 extraction flow
  // without a second RapidAPI roundtrip. Legacy rows default to false
  // until the next health-check refresh sets it.
  hasPostsInfo           Boolean   @default(false)
  // When did we last run /user/posts against this account for the
  // engagement pool? Null = never. Extract flow re-picks after 30d.
  engagementCheckedAt    DateTime?
  engagementPostsFound   Int?
  // True when the last extract pass returned zero qualifying posts —
  // skip on future passes until the parent is re-checked (the 30d
  // revisit window clears this flag).
  engagementExhausted    Boolean   @default(false)

  // 'big_account_followers' | 'random_username' | 'manual'
  scrapeSource           String?
  scrapeSeedAccount      String?

  // 'banned' | 'became_active' | 'became_private' | 'deleted' | 'other'
  invalidReason          String?
  invalidatedAt          DateTime?

  notes                  String?

  testOrders             TestOrder[]
  posts                  TestPost[]

  @@unique([platform, username])
  @@index([platform, active])
  @@index([platform, status])
  @@index([status, assignedAt])
  @@index([platform, status, firstSeenAt])
  @@index([platform, userId])
  // Supports the daily health-check's orderBy: {lastCheckedAt: "asc"}
  // filtered by status='available'. Without it the 6-hourly cron
  // sorts in-memory, which doesn't scale past a few thousand rows.
  @@index([status, lastCheckedAt])
  // Supports testbot's pickAndAssignAccount routing by accountType
  // and detectedCountry.
  @@index([platform, status, accountType, detectedCountry])
}

// A single post / reel / video that lives in the engagement pool.
//
// The engagement pool is a pool of POSTS — not accounts. When a likes /
// views / shares / saves service is tested we pick one TestPost at a
// time (not its parent account), hand its URL to BulkMedya, and flip
// it available → assigned → consumed. A single parent TestAccount can
// contribute N posts if they all pass the freshness + natural-likes
// filters, so one scraped account can fuel several tests instead of
// exactly one.
//
// The parent TestAccount FK is kept for traceability (detectedCountry
// routing, health-check cascades) but does NOT carry the engagement
// lifecycle anymore — that lives on this row.
model TestPost {
  id                Int       @id @default(autoincrement())
  testAccount       TestAccount @relation(fields: [testAccountId], references: [id], onDelete: Cascade)
  testAccountId     Int
  platform          String    // denormalized from parent for fast filtering
  mediaId           String    // platform-native id (IG pk, TT aweme_id)
  mediaUrl          String    // permalink we hand to BulkMedya
  mediaType         String    // 'post' | 'reel' | 'video'
  postedAt          DateTime?
  naturalLikesCount Int       @default(0)

  // Lifecycle — mirrors TestAccount:
  //   available → assigned → consumed   (normal happy path)
  //   available → invalid                 (deleted / parent banned / etc.)
  status                 String    @default("available")
  active                 Boolean   @default(true)
  assignedTestOrderId    Int?
  assignedAt             DateTime?
  consumedAt             DateTime?
  // 'deleted'         — provider returned 404 on health check
  // 'parent_invalid'  — owner TestAccount became invalid
  // 'manual'          — operator flipped it
  invalidReason          String?
  invalidatedAt          DateTime?

  firstSeenAt            DateTime  @default(now())
  lastCheckedAt          DateTime  @default(now())

  // Where did this post come from?
  //   'from_follower_pool' — phase-1 extract: we already had the
  //                          parent account in the follower pool,
  //                          1 RapidAPI call to fetch its posts.
  //   'seeds'              — phase-2 seed scrape: 2 calls (oracle
  //                          on the candidate + posts).
  scrapeSource           String    @default("seeds")

  @@unique([testAccountId, mediaId])
  @@index([platform, status])
  @@index([status, assignedAt])
  @@index([platform, status, firstSeenAt])
  @@index([status, lastCheckedAt])
  @@index([scrapeSource, status])
}

// Single-row config for the pool system (id=1). Editable from the /pool UI.
model PoolConfig {
  id                               Int      @id @default(1)

  // Auto-refill
  autoRefillEnabled                Boolean  @default(true)
  refillThresholdInstagram         Int      @default(500)
  refillTargetInstagram            Int      @default(1000)
  refillThresholdTiktok            Int      @default(500)
  refillTargetTiktok               Int      @default(1000)

  // RapidAPI budget caps per run. Dropped from 10000/3000 to 3000/
  // 1500 after seeing the daily quota hit ~7500 calls/24h — a tighter
  // ceiling per run amortizes better across the day and leaves
  // headroom for measurement bot + testbot + seeds-health-check.
  maxRapidapiCallsPerScrapeRun     Int      @default(3000)
  maxRapidapiCallsPerHealthcheck   Int      @default(1500)
  maxAttemptsMethodB               Int      @default(5000)
  maxPagesPerSeed                  Int      @default(50)

  // Split between big-account scraping (A) and random-username probing (B)
  methodARatio                     Float    @default(0.7)

  // Global kill switch for Phase B (random-username probing). When
  // false the scraper skips Phase B entirely even if methodARatio < 1,
  // and the /pool UI grays out the Method-B configuration surface.
  methodBEnabled                   Boolean  @default(true)

  // Health check schedule (cron expression — read by the orchestrator)
  healthCheckEnabled               Boolean  @default(true)
  healthCheckCron                  String   @default("0 3 * * *")

  // Fresh-account qualification thresholds. Used BOTH at scrape time
  // (accept candidate when value <= threshold) AND at health-check
  // time (invalidate row when value > threshold). Unified into one
  // config so the two passes can never drift — historically there
  // were separate `maxFollowerCount` (scrape) and `invalidateIf
  // FollowerAbove` (health) fields which got out of sync, letting
  // accounts land in the pool that the next cron would immediately
  // invalidate. That separate field is dropped in this revision.
  //
  // maxMediaCount is effectively disabled (999999) because a profile
  // with a handful of posts is still usable — what matters is that
  // the account isn't tracking anyone yet and has near-zero
  // followers.
  // Platform-split follower thresholds. Instagram uses
  // maxFollowerCount (strict, 5) because IG accounts rarely grow
  // organically without intent. TikTok uses maxFollowerCountTiktok
  // (tolerant, 30) because TT's viral dynamics push even dormant
  // accounts to 5-30 followers through random exposure — a 5-cap
  // there would invalidate perfectly good test accounts.
  maxFollowerCount                 Int      @default(5)
  maxFollowerCountTiktok           Int      @default(30)
  maxMediaCount                    Int      @default(999999)
  maxFollowingCount                Int      @default(100)
  requireNotPrivate                Boolean  @default(true)

  // Stricter health-check guardrail reserved for media_count. Kept
  // separate from maxMediaCount for now since media_count checks
  // might evolve independently (we routinely accept posts at scrape
  // time but could want to flag later growth).
  invalidateIfMediaAbove           Int      @default(999999)

  // ── Engagement pool ──────────────────────────────────────────────
  // When enabled, accounts scraped with mediaCount >= engagementPostsMin
  // are classified as 'engagement_test' candidates and their recent
  // posts are sampled. Those posts feed tests for like / view / share
  // services. Disabled by default so the original follower_test-only
  // pool behaviour is preserved until the operator opts in. Country
  // routing is handled at MyBoost→CONTROL time, not here; TestAccount.
  // detectedCountry is kept for that downstream use.
  engagementPoolEnabled            Boolean  @default(false)
  engagementPoolTargetInstagram    Int      @default(500)
  engagementPoolTargetTiktok       Int      @default(500)
  engagementPostsMin               Int      @default(1)
  engagementLikesMaxPerPost        Int      @default(20)
  engagementFreshnessMaxDays       Int      @default(30)

  // BulkMedya catalog sync cadence. The Vercel cron fires every hour
  // (0 * * * *) but the endpoint gates on this field + lastServices
  // SyncAt — sync actually runs only when the elapsed time since the
  // last successful run ≥ servicesSyncFrequencyHours. Default 1 =
  // every hour (no gating).
  servicesSyncFrequencyHours       Int       @default(1)
  lastServicesSyncAt               DateTime?
  lastServicesSyncResult           Json?
  // In-flight lock for the fire-and-forget manual sync + scheduled
  // cron. Set at dispatch, cleared at completion (or on error). Any
  // second trigger while this is recent (<10 min) gets "already_
  // running". Values older than 10 min are treated as stale locks
  // left by a dead worker and ignored.
  servicesSyncStartedAt            DateTime?

  updatedAt                        DateTime @updatedAt
}

// Big accounts whose followers list we paginate (scrape method A).
model PoolSeedAccount {
  id             Int       @id @default(autoincrement())
  platform       String
  username       String

  // Stable platform-side identifier resolved on the first health check.
  // Lets us survive username renames (which would otherwise break the
  // @@unique([platform, username]) lookup and make the seed unreachable).
  userId         String?

  enabled        Boolean   @default(true)
  priority       Int       @default(0)
  addedAt        DateTime  @default(now())

  // Last time the daily seeds health check verified this seed exists
  // and is still public. Null for never-checked (freshly added) seeds.
  lastCheckedAt  DateTime?

  // Cross-run error streak. The scraper increments this whenever it
  // hits a processing error on the seed (e.g. RapidAPI "Private
  // account"); it resets to 0 on a successful page. When the streak
  // crosses AUTO_DISABLE_PRIVATE_THRESHOLD AND the last reason looks
  // like a private/locked error, the scraper flips enabled=false
  // and logs action='auto_disabled_private' so operators can see
  // why. lastErrorReason records the most recent failure verbatim
  // so the log surfaces the actual provider message.
  consecutiveErrors  Int      @default(0)
  lastErrorReason    String?

  @@unique([platform, username])
  @@index([platform, enabled, priority])
}

// Audit log for the daily seeds health check. One row per decision
// (seed deleted + replaced, seed renamed, ok) so operators can scroll
// recent days' actions when they suspect a seed issue.
model PoolSeedHealthLog {
  id            Int      @id @default(autoincrement())
  platform      String
  // 'ok' | 'renamed' | 'deleted_mort'
  //   | 'replaced_from_cache' | 'cache_empty_refill_triggered'
  //   | 'error' | 'manual_trigger'
  action        String
  seedUsername  String   // username at the time of the check
  newUsername   String?  // rename target, or replacement handle
  reason        String?  // oracle message / transient error detail
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([platform, createdAt])
}

// Username prefixes for the random-probe scraper (method B).
model PoolUsernamePrefix {
  id      Int     @id @default(autoincrement())
  prefix  String  @unique
  enabled Boolean @default(true)
}

// Reserve of pre-generated seed suggestions, topped up by a Claude
// Haiku refill job (cron + on-demand). Reading from this table makes
// the /pool seeds "Suggestions" column instant — no user-visible
// Claude latency. Rows get drained as operators integrate or reject
// entries; the cron keeps the pool at >=100 per platform.
model PoolSeedSuggestionPool {
  id        Int      @id @default(autoincrement())
  platform  String   // 'instagram' | 'tiktok'
  username  String
  createdAt DateTime @default(now())

  @@unique([platform, username])
  @@index([platform, createdAt])
}

// Decision log for the suggested-seeds workflow: each row records
// that a given (platform, username) was either promoted to
// PoolSeedAccount (action='integrated') or dismissed (action='rejected')
// so the /api/pool/seeds/suggestions endpoint never surfaces it again.
model PoolSeedSuggestionAction {
  id        Int      @id @default(autoincrement())
  platform  String
  username  String
  action    String   // 'integrated' | 'rejected'
  actedAt   DateTime @default(now())

  @@unique([platform, username])
  @@index([platform, action])
}

// Run history for scrape / health-check / cleanup jobs, with a
// cooperative stop flag so the orchestrator can bail mid-batch.
model PoolJob {
  id             Int      @id @default(autoincrement())
  jobType        String   // 'scrape' | 'health_check' | 'cleanup'
  platform       String?  // null = multi-platform
  trigger        String   // 'manual' | 'cron' | 'auto_refill'

  status         String   @default("pending")
  // 'pending' | 'running' | 'completed' | 'stopped' | 'error'

  startedAt      DateTime @default(now())
  endedAt        DateTime?

  stats          Json?
  error          String?

  stopRequested  Boolean  @default(false)

  @@index([status, startedAt])
  @@index([jobType, status])
}

model TestOrder {
  id               Int      @id @default(autoincrement())
  service          Service  @relation(fields: [serviceId], references: [id])
  serviceId        Int
  testAccount      TestAccount @relation(fields: [testAccountId], references: [id])
  testAccountId    Int
  bulkmedyaOrderId String   @unique
  targetQuantity   Int
  baselineCount    Int
  placedAt         DateTime @default(now())
  completedAt      DateTime?
  measurements     Measurement[]

  @@index([serviceId, placedAt])
}

model Measurement {
  id           Int      @id @default(autoincrement())
  testOrder    TestOrder @relation(fields: [testOrderId], references: [id])
  testOrderId  Int
  checkedAt    DateTime @default(now())
  checkpoint   String
  actualCount  Int
  realismData  Json
  realismScore Float?

  @@unique([testOrderId, checkpoint])
  @@index([testOrderId, checkedAt])
}

model ServiceScore {
  id               Int      @id @default(autoincrement())
  service          Service  @relation(fields: [serviceId], references: [id])
  serviceId        Int
  currentScore     Float
  completionFactor Float
  realismScore     Float
  speedScore       Float
  dropScore        Float
  computedAt       DateTime @default(now())

  @@index([serviceId, computedAt])
}

model RoutingDecision {
  id                 Int      @id @default(autoincrement())
  platform           String
  serviceType        String
  quantity           Int
  targetUrl          String
  chosenServiceId    Int?
  chosenServiceScore Float?
  bulkmedyaOrderId   String?
  attempts           Int      @default(1)
  success            Boolean
  dryRun             Boolean  @default(false)
  errorMessage       String?
  decidedAt          DateTime @default(now())

  @@index([decidedAt])
  @@index([chosenServiceId])
  @@index([success, dryRun])
}

model Config {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// Single-row (id=1) kill switch for each major subsystem. Every gated
// endpoint reads this once per request and 503s / skips if its toggle
// is false. Default: everything ENABLED so an empty row acts as a
// no-op, never a surprise outage.
model SystemToggle {
  id                       Int      @id @default(1)
  poolScrapeEnabled        Boolean  @default(true)
  poolHealthcheckEnabled   Boolean  @default(true)
  routingApiEnabled        Boolean  @default(true)
  testBotEnabled           Boolean  @default(true)
  scoringEngineEnabled     Boolean  @default(true)
  updatedAt                DateTime @updatedAt
}
